{
  "name": "light-mem",
  "version": "0.1.6",
  "description": "Lightweight persistent memory for Claude Code and OpenCode. In-process embeddings, no external services.",
  "keywords": [
    "claude",
    "claude-code",
    "opencode",
    "claude-agent-sdk",
    "mcp",
    "plugin",
    "memory",
    "embeddings",
    "model2vec",
    "sqlite",
    "transcript",
    "typescript",
    "nodejs"
  ],
  "author": "DevEstacion",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DevEstacion/light-mem.git"
  },
  "homepage": "https://github.com/DevEstacion/light-mem#readme",
  "bugs": {
    "url": "https://github.com/DevEstacion/light-mem/issues"
  },
  "type": "module",
  "bin": {
    "light-mem": "./dist/npx-cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./sdk": {
      "types": "./dist/sdk/index.d.ts",
      "import": "./dist/sdk/index.js"
    },
    "./modes/*": "./plugin/modes/*"
  },
  "files": [
    "dist",
    ".agents/plugins/marketplace.json",
    "plugin/.claude-plugin",
    "plugin/.mcp.json",
    "plugin/package.json",
    "plugin/hooks",
    "plugin/modes",
    "plugin/scripts/*.js",
    "plugin/scripts/*.cjs",
    "plugin/skills",
    "plugin/ui",
    "plugin/integrations/**",
    "plugin/models/**"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "npm run build-and-sync",
    "build": "node scripts/sync-plugin-manifests.js && node scripts/build-hooks.js",
    "build-and-sync": "npm run build && npm run sync-marketplace && (cd ~/.claude/plugins/marketplaces/light-mem && npm run worker:restart)",
    "sync-marketplace": "node scripts/sync-marketplace.cjs",
    "sync-marketplace:force": "node scripts/sync-marketplace.cjs --force",
    "worker:logs": "tail -n 50 ~/.light-mem/logs/worker-$(date +%Y-%m-%d).log",
    "worker:tail": "tail -f 50 ~/.light-mem/logs/worker-$(date +%Y-%m-%d).log",
    "changelog:generate": "node scripts/generate-changelog.js",
    "discord:notify": "node scripts/discord-release-notify.js",
    "worker:start": "node plugin/scripts/worker-service.cjs start",
    "worker:stop": "node plugin/scripts/worker-service.cjs stop",
    "worker:restart": "node plugin/scripts/worker-service.cjs restart",
    "worker:status": "node plugin/scripts/worker-service.cjs status",
    "queue": "tsx scripts/check-pending-queue.ts",
    "queue:process": "tsx scripts/check-pending-queue.ts --process",
    "queue:clear:pending": "tsx scripts/clear-pending-queue.ts --all --force",
    "pr:status": "tsx scripts/pr-babysit-status.ts",
    "claude-md:regenerate": "tsx scripts/regenerate-claude-md.ts",
    "claude-md:dry-run": "tsx scripts/regenerate-claude-md.ts --dry-run",
    "strip-comments": "tsx scripts/strip-comments.ts",
    "strip-comments:check": "tsx scripts/strip-comments.ts --check",
    "strip-comments:dry-run": "tsx scripts/strip-comments.ts --dry-run",
    "bug-report": "npx tsx scripts/bug-report/cli.ts",
    "lint:hook-io": "node scripts/check-hook-io-discipline.cjs",
    "lint:spawn-env": "node scripts/check-spawn-env-discipline.cjs",
    "typecheck": "tsc --noEmit && tsc --noEmit -p src/ui/viewer/tsconfig.json",
    "typecheck:root": "tsc --noEmit",
    "typecheck:viewer": "tsc --noEmit -p src/ui/viewer/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:sqlite": "vitest run tests/sqlite/",
    "test:agents": "vitest run tests/worker/agents/",
    "test:search": "vitest run tests/worker/search/",
    "test:context": "vitest run tests/context/",
    "test:infra": "vitest run tests/infrastructure/",
    "test:server": "vitest run tests/server/",
    "check:postinstall-allowlist": "node scripts/check-postinstall-allowlist.js",
    "smoke:clean-room": "node scripts/smoke-clean-room.cjs",
    "prepublishOnly": "npm run build && node scripts/check-postinstall-allowlist.js",
    "version:bump": "node scripts/bump-version.cjs patch",
    "version:bump:minor": "node scripts/bump-version.cjs minor",
    "version:bump:major": "node scripts/bump-version.cjs major",
    "hooks:install": "bash scripts/install-hooks.sh"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "tag": "latest"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.172",
    "@better-auth/api-key": "^1.6.16",
    "@clack/prompts": "^1.3.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ansi-to-html": "^0.7.2",
    "better-auth": "^1.6.16",
    "cors": "^2.8.6",
    "dompurify": "^3.4.9",
    "express": "^5.2.1",
    "glob": "^13.0.6",
    "handlebars": "^4.7.9",
    "picocolors": "^1.1.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "shell-quote": "^1.8.3",
    "yaml": "^2.8.4",
    "zod": "^4.4.3",
    "zod-to-json-schema": "^3.25.2"
  },
  "overrides": {
    "tmp": "^0.2.7"
  },
  "devDependencies": {
    "@derekstride/tree-sitter-sql": "^0.3.11",
    "@tree-sitter-grammars/tree-sitter-lua": "^0.4.1",
    "@tree-sitter-grammars/tree-sitter-markdown": "^0.3.2",
    "@tree-sitter-grammars/tree-sitter-toml": "^0.7.0",
    "@tree-sitter-grammars/tree-sitter-yaml": "^0.7.1",
    "@tree-sitter-grammars/tree-sitter-zig": "^1.1.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.0",
    "jimp": "^1.6.1",
    "parse5": "^8.0.1",
    "postcss": "^8.5.14",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "tree-sitter-bash": "^0.25.1",
    "tree-sitter-c": "^0.24.1",
    "tree-sitter-cli": "^0.26.8",
    "tree-sitter-cpp": "^0.23.4",
    "tree-sitter-css": "^0.25.0",
    "tree-sitter-elixir": "^0.3.5",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-haskell": "^0.23.1",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-kotlin": "^0.3.8",
    "tree-sitter-php": "^0.24.2",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-ruby": "^0.23.1",
    "tree-sitter-rust": "^0.24.0",
    "tree-sitter-scala": "^0.24.0",
    "tree-sitter-scss": "^1.0.0",
    "tree-sitter-swift": "^0.7.1",
    "tree-sitter-typescript": "^0.23.2",
    "ts-prune": "^0.10.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.8"
  },
  "optionalDependencies": {
    "tree-kill": "^1.2.2"
  }
}
